SEQ_LEN = 64
ACTION_FRAMES = 16
INPUT_DIM = 102
NUM_CLASSES = 288

CONF_THRESHOLD = 0.03
END_MISSING_FRAMES = 5

BODY_POSE_IDXS = [0, 9, 10, 11, 12, 13, 14, 15, 16]

BANNED_WORDS = {"瘦"}

LABEL_REMAP = {
    168: 186,   # 老人 -> 我
    105: 99,    # 多 -> 有
    273: 80,    # 经验 -> 困难
}

