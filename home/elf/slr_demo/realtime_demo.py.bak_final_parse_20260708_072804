import cv2
import time
import os
import numpy as np
from collections import deque
from rknnlite.api import RKNNLite


BODY_MODEL = "body_pose.rknn"
HAND_MODEL = "hand_pose.rknn"
SLR_MODEL = "sign_tcn_64x46.rknn"
DICT_PATH = "dictionary.txt"

IMG_SIZE = 640
SEQ_LEN = 64

# 降低 SLR 模型调用频率
# 原来是 8，改成 16 更省算力
SLR_INTERVAL = 32

# 降低 body_pose / hand_pose 模型调用频率
# 1 = 每帧都跑，最耗算力
# 2 = 每 2 帧跑一次，算力大约降低一半
# 3 = 每 3 帧跑一次，更省，但延迟更高
POSE_INTERVAL = 4

SHOW_W = 800
SHOW_H = 480

CAMERA_PIPELINE = (
    "v4l2src device=/dev/video52 ! "
    "video/x-raw,format=NV12,width=640,height=480 ! "
    "videoconvert ! "
    "video/x-raw,format=BGR ! "
    "appsink max-buffers=1 drop=true sync=false"
)

BODY_IDXS = [0, 5, 6, 7, 8, 9]
HAND_NUM = 17

seq_buffer = deque(maxlen=SEQ_LEN)


def read_board_temp():
    root = "/sys/class/thermal"
    temps = []

    if not os.path.exists(root):
        return None

    for name in os.listdir(root):
        if not name.startswith("thermal_zone"):
            continue

        path = os.path.join(root, name, "temp")
        if not os.path.exists(path):
            continue

        try:
            with open(path, "r") as f:
                v = int(f.read().strip())

            if v > 1000:
                v = v / 1000.0

            temps.append(v)
        except Exception:
            pass

    if not temps:
        return None

    return max(temps)



def load_dict(path):
    """
    读取旧 dictionary.txt。
    支持格式：
    0 词语
    000 词语
    0\t词语
    """
    id2word = {}

    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()

            if not line:
                continue

            parts = line.split()

            if len(parts) < 2:
                continue

            try:
                idx = int(parts[0])
                word = "".join(parts[1:])
                id2word[idx] = word
            except Exception:
                continue

    print("load dict:", path, "classes:", len(id2word))
    return id2word


def load_rknn(path):
    rknn = RKNNLite()

    ret = rknn.load_rknn(path)
    if ret != 0:
        raise RuntimeError("load failed: " + path)

    ret = rknn.init_runtime()
    if ret != 0:
        raise RuntimeError("init runtime failed: " + path)

    return rknn


def letterbox(img, size=640):
    h, w = img.shape[:2]

    scale = min(size / w, size / h)

    nw = int(w * scale)
    nh = int(h * scale)

    resized = cv2.resize(img, (nw, nh))

    canvas = np.full((size, size, 3), 114, dtype=np.uint8)

    dw = (size - nw) // 2
    dh = (size - nh) // 2

    canvas[dh:dh + nh, dw:dw + nw] = resized

    return canvas, scale, dw, dh


def preprocess(img):
    img, scale, dw, dh = letterbox(img, IMG_SIZE)

    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    # 保持你原来的输入格式，避免模型输入不匹配
    img = img.astype(np.float32) / 255.0

    img = img.transpose(2, 0, 1)
    img = np.expand_dims(img, axis=0)

    return img, scale, dw, dh


def _parse_yolo_pose_old(output, num_kpts, scale, dw, dh, frame_w, frame_h):
    if output is None:
        return None, 0.0

    out = output

    if isinstance(out, list):
        if len(out) == 0 or out[0] is None:
            return None, 0.0
        out = out[0]

    out = np.array(out)

    if out.ndim == 3:
        out = out[0]

    if out.shape[0] < out.shape[1]:
        out = out.T

    need_dim = 5 + num_kpts * 3
    if out.shape[1] < need_dim:
        return None, 0.0

    conf = out[:, 4]
    best = int(np.argmax(conf))
    best_score = float(conf[best])

    if best_score < 0.25:
        return None, best_score

    data = out[best]
    kpts = data[5:5 + num_kpts * 3].reshape(num_kpts, 3)

    xy = kpts[:, :2].astype(np.float32)

    xy[:, 0] = (xy[:, 0] - dw) / scale
    xy[:, 1] = (xy[:, 1] - dh) / scale

    xy[:, 0] = np.clip(xy[:, 0], 0, frame_w - 1)
    xy[:, 1] = np.clip(xy[:, 1], 0, frame_h - 1)

    return xy, best_score


def make_46_feature(hand_xy, body_xy, frame_w, frame_h):
    feat = []

    if hand_xy is None:
        feat.extend([0.0] * 34)
    else:
        hand_xy = hand_xy[:HAND_NUM]

        for x, y in hand_xy:
            feat.append(float(x) / frame_w)
            feat.append(float(y) / frame_h)

        while len(feat) < 34:
            feat.append(0.0)

    if body_xy is None:
        feat.extend([0.0] * 12)
    else:
        for idx in BODY_IDXS:
            if idx < len(body_xy):
                x, y = body_xy[idx]
                feat.append(float(x) / frame_w)
                feat.append(float(y) / frame_h)
            else:
                feat.extend([0.0, 0.0])

    feat = np.array(feat, dtype=np.float32)

    body = feat[34:].reshape(-1, 2)

    if body.shape[0] >= 3:
        ls = body[1]
        rs = body[2]

        if np.any(ls != 0) and np.any(rs != 0):
            cx = (ls[0] + rs[0]) / 2.0
            cy = (ls[1] + rs[1]) / 2.0

            feat[0::2] -= cx
            feat[1::2] -= cy

    return feat


def softmax(x):
    x = x.astype(np.float32)
    x = x - np.max(x, axis=-1, keepdims=True)
    e = np.exp(x)
    return e / np.sum(e, axis=-1, keepdims=True)


def parse_slr_output(output):
    if output is None:
        return -1, 0.0

    out = output

    if isinstance(out, list):
        if len(out) == 0 or out[0] is None:
            return -1, 0.0
        out = out[0]

    out = np.array(out)

    if out.ndim == 3:
        out = out[0]

    if out.ndim == 2:
        out = out[-1]

    prob = softmax(out)
    pred_id = int(np.argmax(prob))
    pred_score = float(prob[pred_id])

    return pred_id, pred_score


def draw_points(frame, hand_xy, body_xy):
    if hand_xy is not None:
        for x, y in hand_xy[:HAND_NUM]:
            cv2.circle(frame, (int(x), int(y)), 4, (0, 255, 0), -1)

    if body_xy is not None:
        for idx in BODY_IDXS:
            if idx < len(body_xy):
                x, y = body_xy[idx]
                cv2.circle(frame, (int(x), int(y)), 5, (255, 0, 0), -1)


def draw_info(frame, fps, pred_id, pred_score, body_score, hand_score):
    temp = read_board_temp()

    cv2.putText(
        frame,
        "FPS: %.1f" % fps,
        (20, 35),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.8,
        (0, 255, 255),
        2,
    )

    if temp is not None:
        cv2.putText(
            frame,
            "TEMP: %.1fC" % temp,
            (20, 70),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.8,
            (0, 255, 255),
            2,
        )

    cv2.putText(
        frame,
        "SLR ID: %d  SCORE: %.2f" % (pred_id, pred_score),
        (20, 105),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.8,
        (0, 255, 0),
        2,
    )

    cv2.putText(
        frame,
        "BODY: %.2f  HAND: %.2f" % (body_score, hand_score),
        (20, 140),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.7,
        (0, 255, 0),
        2,
    )

    cv2.putText(
        frame,
        "POSE_INTERVAL: %d  SLR_INTERVAL: %d" % (POSE_INTERVAL, SLR_INTERVAL),
        (20, 175),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.6,
        (255, 255, 0),
        2,
    )


def main():
    print("load RKNN models...")

    body_rknn = load_rknn(BODY_MODEL)
    hand_rknn = load_rknn(HAND_MODEL)
    slr_rknn = load_rknn(SLR_MODEL)

    print("open camera /dev/video52 ...")

    cap = cv2.VideoCapture("/dev/video52", cv2.CAP_V4L2)

    if not cap.isOpened():
        print("camera open failed")
        return

    print("camera ok, start demo")

    pred_id = -1
    pred_score = 0.0

    total_frames = 0
    fps_frames = 0
    last_time = time.time()
    fps = 0.0

    last_body_xy = None
    last_hand_xy = None
    last_body_score = 0.0
    last_hand_score = 0.0

    cv2.namedWindow("SLR Demo", cv2.WINDOW_NORMAL)
    cv2.resizeWindow("SLR Demo", SHOW_W, SHOW_H)

    try:
        while True:
            ret, frame = cap.read()

            if not ret or frame is None:
                print("read frame failed")
                time.sleep(0.05)
                continue

            total_frames += 1
            fps_frames += 1

            frame_h, frame_w = frame.shape[:2]

            # 核心降算力：
            # 不再每帧都跑 body_pose 和 hand_pose
            # 只在指定间隔帧推理，其余帧复用上一次结果
            if total_frames % POSE_INTERVAL == 0:
                inp, scale, dw, dh = preprocess(frame)

                body_out = body_rknn.inference(inputs=[inp])
                hand_out = hand_rknn.inference(inputs=[inp])

                body_xy, body_score = parse_yolo_pose(
                    body_out,
                    17,
                    scale,
                    dw,
                    dh,
                    frame_w,
                    frame_h,
                )

                hand_xy, hand_score = parse_yolo_pose(
                    hand_out,
                    21,
                    scale,
                    dw,
                    dh,
                    frame_w,
                    frame_h,
                )

                last_body_xy = body_xy
                last_hand_xy = hand_xy
                last_body_score = body_score
                last_hand_score = hand_score

            else:
                body_xy = last_body_xy
                hand_xy = last_hand_xy
                body_score = last_body_score
                hand_score = last_hand_score

            feat = make_46_feature(hand_xy, body_xy, frame_w, frame_h)
            seq_buffer.append(feat)

            # SLR 模型也降低调用频率
            if len(seq_buffer) == SEQ_LEN and total_frames % SLR_INTERVAL == 0:
                seq = np.array(seq_buffer, dtype=np.float32)

                # 默认输入 [1, 64, 46]
                slr_inp = np.expand_dims(seq, axis=0)

                slr_out = slr_rknn.inference(inputs=[slr_inp])
                pred_id, pred_score = parse_slr_output(slr_out)

            draw_points(frame, hand_xy, body_xy)
            draw_info(frame, fps, pred_id, pred_score, body_score, hand_score)

            show_frame = cv2.resize(frame, (SHOW_W, SHOW_H))
            cv2.imshow("SLR Demo", show_frame)

            now = time.time()
            dt = now - last_time

            if dt >= 1.0:
                fps = fps_frames / dt
                fps_frames = 0
                last_time = now

            key = cv2.waitKey(1) & 0xFF

            if key == ord("q"):
                break

    except KeyboardInterrupt:
        print("exit by keyboard")

    finally:
        cap.release()
        cv2.destroyAllWindows()

        body_rknn.release()
        hand_rknn.release()
        slr_rknn.release()


if __name__ == "__main__":
    main()


# ===== safe wrapper: 防止 parse_yolo_pose 返回 None 导致 UI 报错 =====
def parse_yolo_pose(*args, **kwargs):
    try:
        ret = _parse_yolo_pose_old(*args, **kwargs)

        if ret is None:
            return None, 0.0

        if isinstance(ret, tuple):
            if len(ret) == 2:
                return ret
            if len(ret) == 1:
                return ret[0], 0.0

        return ret, 0.0

    except Exception as e:
        print("[safe parse_yolo_pose] error:", repr(e))
        return None, 0.0
